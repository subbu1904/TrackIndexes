# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will not be committed.

# URL of your deployed Cloudflare Worker proxy.
# When this is set, the app uses YahooFinanceProvider (live data).
# When this is NOT set, the app uses MockProvider (fake data for development).
# Example: VITE_PROXY_URL=https://trackindexes-proxy.your-subdomain.workers.dev
VITE_PROXY_URL=
