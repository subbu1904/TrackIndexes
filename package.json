{
  "name": "trackindexes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test",
    "cap:sync": "npx cap sync android",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "worker:d1:migrate:local": "wrangler d1 migrations apply trackindexes --local --config worker/wrangler.toml",
    "worker:d1:migrate": "wrangler d1 migrations apply trackindexes --remote --config worker/wrangler.toml"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "vite": "^7.1.0",
    "vite-plugin-pwa": "^1.0.0",
    "wrangler": "^4.82.2"
  }
}
