{
  "name": "track-indexes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:capacitor": "tsc && vite build --mode capacitor",
    "android:sync": "npm run build:capacitor && npx cap sync android && node scripts/patch-capacitor-java17.mjs",
    "android:apk:debug": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "test": "bun test",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@tanstack/react-query": "^5.28.0",
    "idb-keyval": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-pwa": "^0.20.0"
  }
}
